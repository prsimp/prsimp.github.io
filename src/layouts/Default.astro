---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content="Paul Simpson" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <script is:inline src="https://use.typekit.com/lob8uru.js"></script>
    <script is:inline>try{Typekit.load();}catch(e){}</script>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="logo">
          <a href="/"><h1>Paul Simpson</h1></a>
        </div>
        <nav>
          <ul>
            <li><a href="/about">about</a></li>
            <li><a href="http://prsimp.github.com/">projects</a></li>
            <li><a href="https://github.com/prsimp/feedback/issues/new">ask me</a></li>
            <li><a href="/archives">archives</a></li>
          </ul>
        </nav>
      </header>
      <slot />
      <footer></footer>
    </div>
  </body>
</html>
