---
interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Writing about tech, life, and whatever else.',
  ogType = 'website',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const pageTitle = title === 'Paul Simpson' ? title : `${title} | Paul Simpson`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content="Paul Simpson" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Paul Simpson" />

    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Paul Simpson"
      href="/rss.xml"
    />

    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <script is:inline src="https://use.typekit.com/lob8uru.js"></script>
    <script is:inline>
      try {
        Typekit.load();
      } catch (_e) {}
    </script>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="logo">
          <a href="/"><h1>Paul Simpson</h1></a>
        </div>
        <nav>
          <ul>
            <li><a href="/about">about</a></li>
            <li><a href="/projects">projects</a></li>
            <li>
              <a href="https://github.com/prsimp/feedback/issues/new">ask me</a>
            </li>
            <li><a href="/archives">archives</a></li>
          </ul>
        </nav>
      </header>
      <slot />
      <footer></footer>
    </div>
  </body>
</html>
